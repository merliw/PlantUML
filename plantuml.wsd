@startuml

class User {
    - name : String
    - role : String
    - department : String
    - workstation : Workstation
    + login()
    + logout()
}

class Workstation {
    - hostname : String
    - ipAddress : String
    - macAddress : String
    + start()
    + shutdown()
}

User "1" -- "1" Workstation : uses

@enduml